# ============================================================
# Signet — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
# Service-role key — server-side only, never expose to client
VITE_SUPABASE_ACCESS_TOKEN=<your-access-token>

# Stripe (test keys safe for development)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-publishable-key>
# SECRET — server-side only. Never prefix with VITE_
STRIPE_SECRET_KEY=sk_test_<your-secret-key>

# Sentry
# DSN is client-safe (read-only ingest endpoint) but keep out of source
VITE_SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project>
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=1.0.0

# Sentry feature flags
# Set to "true" to enable consoleLoggingIntegration + enableLogs pipeline
VITE_SENTRY_ENABLE_LOGS=false
# Set to "true" to send PII (IP address, user agent) to Sentry — prod only
VITE_SENTRY_ENABLE_PII=false

# Sentry performance (optional overrides)
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=0.5
SENTRY_RELEASE=1.0.0

# AI APIs
VITE_GEMINI_API_KEY=<your-gemini-api-key>
VITE_OPENROUTER_API_KEY=<your-openrouter-api-key>
VITE_NVIDIA_API_KEY=<your-nvidia-api-key>
VITE_MISTRAL_API_KEY=<your-mistral-api-key>
SERPAPI_API_KEY=<your-serpapi-api-key>

# Chromatic (CI only — not needed locally unless running chromatic)
CHROMATIC_PROJECT_TOKEN=<your-chromatic-project-token>
