# ──────────────────────────────────────────────────────────────────────────────
# Signet — Supabase Edge Functions Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (auto-provided in hosted Edge Functions) ──────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NVIDIA NIM (Primary AI Provider) ──────────────────────────────────────
# Used by: reforge-datacore, distill-competencies, target-lock
# Get a key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxxxx

# ── Google Gemini (Fallback AI Provider) ──────────────────────────────────
# Used by: shared AI client (cascading fallback)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxx

# ── OpenAI (Tertiary AI Provider) ─────────────────────────────────────────
# Used by: shared AI client (cascading fallback)
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# ── SerpAPI (Company Intelligence for Target Lock) ────────────────────────
# Used by: target-lock
# Get a key at: https://serpapi.com/
SERPAPI_API_KEY=xxxxx

# ── Stripe (Payments) ────────────────────────────────────────────────────
# Used by: stripe-checkout, stripe-webhook
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
